<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="?attr/materialCardViewStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivBuildingIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_building"
                android:background="?attr/colorSurfaceVariant"
                app:tint="?attr/colorPrimary"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tvRoomName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:textAppearance="@style/TextAppearance.App.LabelTitle"
                android:textSize="22sp"
                app:layout_constraintBottom_toBottomOf="@+id/ivBuildingIcon"
                app:layout_constraintEnd_toStartOf="@+id/btnQuickEdit"
                app:layout_constraintStart_toEndOf="@+id/ivBuildingIcon"
                app:layout_constraintTop_toTopOf="@+id/ivBuildingIcon"
                tools:text="Room 101" />

            <ImageView
                android:id="@+id/btnQuickEdit"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_edit"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurfaceVariant"
                app:layout_constraintBottom_toBottomOf="@+id/ivBuildingIcon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/ivBuildingIcon"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tvTenantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textAppearance="@style/TextAppearance.App.LabelBody"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@+id/ivBuildingIcon"
                tools:text="Tenant: Alex Johnson" />

            <TextView
                android:id="@+id/tvSubmeterSerial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.App.LabelBody"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@+id/tvTenantName"
                tools:text="Submeter Serial: MM101A" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="4dp"
                android:background="?attr/colorPrimaryContainer"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvSubmeterSerial"
                tools:text="Active" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Themed Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorSurfaceVariant" />

        <!-- Bottom Action Row Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/colorSurface"
            android:visibility="gone">

            <ImageView
                android:id="@+id/btnActionEdit"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:src="@drawable/ic_edit"
                android:visibility="gone"

                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                app:tint="?attr/colorPrimary"
                tools:ignore="ContentDescription" />

            <ImageView
                android:id="@+id/btnActionDelete"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:src="@drawable/ic_delete"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                app:tint="?attr/colorError"
                android:visibility="gone"
                tools:ignore="ContentDescription" />

            <ImageView
                android:id="@+id/btnActionTenant"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:src="@drawable/ic_person_edit"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                app:tint="?attr/colorPrimary"
                android:visibility="gone"
                tools:ignore="ContentDescription" />

        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilQrCode"
            style="?attr/textInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:hint="Encrypted QR Code"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_gallery"
            app:endIconTint="?attr/colorPrimary"
            app:endIconContentDescription="Copy Text payload">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEncryptedRoomNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:maxLength="5000"
                android:maxLines="6"
                android:scrollbars="vertical"
                android:textSize="14sp"
                android:textAppearance="@style/TextAppearance.App.LabelBody"
                tools:text="Please get the Qr Code from here -->>" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>