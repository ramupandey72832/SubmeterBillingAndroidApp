<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurfaceVariant"
    tools:context=".fragments.EndRoomTenancyFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Section -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textAppearance="@style/TextAppearance.App.LabelTitle"
            android:textColor="?attr/colorPrimary"
            android:textSize="24sp"
            android:text="Process Tenant Move-Out" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:textAppearance="@style/TextAppearance.App.LabelBody"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:text="This will archive the tenant profile and free up the room for future occupants." />

        <!-- Info Box Container using Tonal Semantic Card Styling -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorPrimaryContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="?attr/colorOnPrimaryContainer"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/TextAppearance.App.LabelTitle"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="13sp"
                    android:text="Tenant history and past bills will be safely archived." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Side-by-Side Container for Room Number and Check Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <!-- Room/Unit Identification -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRoomNumber"
                style="?attr/textInputStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Room Number">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRoomNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Check Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheck"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Check"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Dynamic Tenant Details Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvTenantDetailsContainer"
            style="?attr/materialCardViewStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelTitle"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"
                    android:text="Current Occupant Details" />

                <!-- Tenant Name -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelBody"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:text="Tenant Name" />
                <TextView
                    android:id="@+id/tvTenantName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelTitle"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    tools:text="John Doe" />

                <!-- Identification Meta Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelBody"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:text="Aadhaar Number" />
                <TextView
                    android:id="@+id/tvAadhaarNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelTitle"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    tools:text="XXXX-XXXX-XXXX" />

                <!-- Mobile Number -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelBody"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:text="Mobile Number" />
                <TextView
                    android:id="@+id/tvMobileNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelTitle"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    tools:text="+91 9876543210" />

                <!-- Last Meter Reading -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelBody"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:text="Last Meter Reading" />
                <TextView
                    android:id="@+id/tvLastMeterReading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelTitle"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp"
                    tools:text="1024 kWh" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- End Date Picker Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEndDate"
            style="?attr/textInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="Move-Out Date"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            app:startIconTint="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEndDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Action Buttons Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Complete Checkout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEndTenancy"
                style="?attr/materialButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Complete Move-Out"
                android:layout_marginBottom="12dp"/>

            <!-- Cancel Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:text="Back" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>