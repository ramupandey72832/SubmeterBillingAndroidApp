<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA"
    tools:context=".fragments.EndRoomTenancyFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Section -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Process Tenant Move-Out"
            android:textColor="#1976D2"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="This will archive the tenant profile and free up the room for future occupants."
            android:textColor="#666666"
            android:textSize="14sp" />

        <!-- Info Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#E3F2FD"
            android:padding="12dp"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="#1976D2"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tenant history and past bills will be safely archived."
                android:textColor="#0D47A1"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Side-by-Side Container for Room Number and Check Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <!-- Room/Unit Identification -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRoomNumber"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Room Number">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRoomNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Check Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheck"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:text="Check"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Dynamic Tenant Details Card (Displays after clicking Check) -->
        <LinearLayout
            android:id="@+id/llTenantDetailsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current Occupant Details"
                android:textColor="#1976D2"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Tenant Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tenant Name"
                android:textColor="#888888"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvTenantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#212121"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- Aadhaar Number -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aadhaar Number"
                android:textColor="#888888"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvAadhaarNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#212121"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- Mobile Number -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mobile Number"
                android:textColor="#888888"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvMobileNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#212121"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- Last Meter Reading -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last Meter Reading"
                android:textColor="#888888"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvLastMeterReading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- End Date Picker Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEndDate"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="Move-Out Date"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEndDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Action Buttons Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Complete Checkout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEndTenancy"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Complete Move-Out"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#1976D2"
                app:cornerRadius="8dp"
                android:layout_marginBottom="12dp"/>

            <!-- Cancel Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Cancel"
                android:textColor="#666666"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>