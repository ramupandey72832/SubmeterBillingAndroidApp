<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.tools/"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA"
    tools:context=".DeleteRoomFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Section -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Delete Room"
            android:textColor="#D32F2F"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="Removing a room will also detach any active submeters assigned to it. This action cannot be undone."
            android:textColor="#666666"
            android:textSize="14sp" />

        <!-- Warning Notice Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFEBEE"
            android:padding="12dp"
            android:layout_marginBottom="32dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_alert"
                app:tint="#D32F2F"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Warning: Proceed with caution."
                android:textColor="#C62828"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Room Number Input to Identify -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDeleteRoomNumber"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Enter Room / Unit Number to Delete"
            app:startIconDrawable="@android:drawable/ic_menu_home"
            app:boxStrokeColor="#D32F2F"
            app:hintTextColor="#D32F2F">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDeleteRoomNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Safety Confirmation Input (Optional but recommended for UX) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilConfirmDelete"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="Type 'DELETE' to confirm"
            app:startIconDrawable="@android:drawable/ic_menu_edit">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etConfirmDelete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Action Buttons Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Delete Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteRoom"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Permanently Delete Room"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#D32F2F"
                app:cornerRadius="8dp"
                android:layout_marginBottom="12dp"/>

            <!-- Cancel Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelDelete"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Cancel"
                android:textColor="#666666"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>