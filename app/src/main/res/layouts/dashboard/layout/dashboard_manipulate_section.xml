<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:padding="@dimen/card_padding_normal">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding_large"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Header Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/section_margin_bottom">

                <TextView
                    android:id="@+id/tvHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Submeter &amp; Tenancy"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="@dimen/text_size_header"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerInParent="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/status_icon_size"
                        android:layout_height="@dimen/status_icon_size"
                        android:src="@android:drawable/ic_menu_info_details"
                        app:tint="?android:attr/textColorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/status_text_margin"
                        android:text="Active Overview"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/text_size_caption" />
                </LinearLayout>
            </RelativeLayout>

            <!-- 2x2 Action Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2"
                android:alignmentMode="alignBounds"
                android:rowOrderPreserved="false"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Action: Add Room -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/grid_item_padding"
                    android:paddingBottom="@dimen/grid_item_padding"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <FrameLayout
                        android:layout_width="@dimen/icon_container_size"
                        android:layout_height="@dimen/icon_container_size"
                        android:id="@+id/addRoom"
                        android:background="@drawable/bg_circle_icon"
                        android:layout_gravity="center_horizontal">
                        <ImageView
                            android:layout_width="@dimen/action_icon_size"
                            android:layout_height="@dimen/action_icon_size"
                            android:layout_gravity="center"
                            app:tint="?attr/colorPrimary"
                            android:src="@android:drawable/ic_menu_add" />
                    </FrameLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/label_margin_top"
                        android:gravity="center"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_size_label"
                        android:text="Add Room" />
                </LinearLayout>

                <!-- Action: Add Tenant -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/grid_item_padding"
                    android:paddingBottom="@dimen/grid_item_padding"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <FrameLayout
                        android:layout_width="@dimen/icon_container_size"
                        android:layout_height="@dimen/icon_container_size"
                        android:id="@+id/addTenant"
                        android:background="@drawable/bg_circle_icon"
                        android:layout_gravity="center_horizontal">
                        <ImageView
                            android:layout_width="@dimen/action_icon_size"
                            android:layout_height="@dimen/action_icon_size"
                            android:layout_gravity="center"
                            app:tint="?attr/colorPrimary"
                            android:src="@drawable/ic_menu_btn_add" />
                    </FrameLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/label_margin_top"
                        android:gravity="center"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_size_label"
                        android:text="Add Tenant" />
                </LinearLayout>

                <!-- Action: Delete Submeter -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/grid_item_padding"
                    android:paddingBottom="@dimen/grid_item_padding"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <FrameLayout
                        android:layout_width="@dimen/icon_container_size"
                        android:layout_height="@dimen/icon_container_size"
                        android:background="@drawable/bg_circle_icon"
                        android:layout_gravity="center_horizontal">
                        <ImageView
                            android:layout_width="@dimen/action_icon_size"
                            android:layout_height="@dimen/action_icon_size"
                            android:layout_gravity="center"
                            app:tint="?attr/colorError"
                            android:src="@android:drawable/ic_menu_delete" />
                    </FrameLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/label_margin_top"
                        android:gravity="center"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_size_label"
                        android:text="Delete Submeter" />
                </LinearLayout>

                <!-- Action: Delete Tenancy -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/grid_item_padding"
                    android:paddingBottom="@dimen/grid_item_padding"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <FrameLayout
                        android:layout_width="@dimen/icon_container_size"
                        android:layout_height="@dimen/icon_container_size"
                        android:background="@drawable/bg_circle_icon"
                        android:layout_gravity="center_horizontal">
                        <ImageView
                            android:layout_width="@dimen/action_icon_size"
                            android:layout_height="@dimen/action_icon_size"
                            android:layout_gravity="center"
                            app:tint="?attr/colorError"
                            android:src="@android:drawable/ic_delete" />
                    </FrameLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/label_margin_top"
                        android:gravity="center"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_size_label"
                        android:text="Delete Tenancy" />
                </LinearLayout>

            </GridLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>