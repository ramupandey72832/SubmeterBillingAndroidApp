<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#D2EBE9"> <!-- Light teal background tint matching the image -->

    <!-- Custom Top Action Bar / Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#212121"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btnBack"
            android:layout_centerVertical="true"
            android:layout_marginStart="24dp"
            android:text="Generate Bill for Room 101"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Main Card Body Container -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F7FCFC">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Tenant Info Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tenant:"
                    android:textColor="#666666"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvTenantName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alex Johnson"
                    android:textColor="#212121"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/tvRoomNumberLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Room 101"
                    android:textColor="#444444"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp" />

                <!-- Scan Subtitle Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pre-filled Readings (detected from scan)"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp" />

                <!-- Initial Reading Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Initial Reading (01 Mar):"
                        android:textColor="#444444"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tvInitialReading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="110.1 kWh"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Final Reading Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Final Reading (01 Apr):"
                        android:textColor="#444444"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tvFinalReading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="123.4 kWh"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- View OCR Link Button -->
                <TextView
                    android:id="@+id/btnViewOcr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="View OCR Image"
                    android:textColor="#1A7F75"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Units Consumed Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Units Consumed"
                        android:textColor="#444444"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tvUnitsConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="13.3 kWh"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Unit Rate Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unit Rate"
                        android:textColor="#444444"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tvUnitRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="₹10/kWh"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Calculation Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calculation"
                        android:textColor="#444444"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tvCalculation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="13.3 * 10 = ₹133"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Fixed Charges Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plus Fixed Charges"
                        android:textColor="#444444"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tvFixedCharges"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="₹100"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Horizontal Separator Line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5EAEB"
                    android:layout_marginBottom="16dp" />

                <!-- Total Bill Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="40dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Bill Amount"
                        android:textColor="#212121"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvTotalAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="₹233"
                        android:textColor="#212121"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Bottom Action Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGenerateSendBill"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Generate &amp; Send Bill"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    app:backgroundTint="#0C8276"
                    app:cornerRadius="26dp" />

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</LinearLayout>