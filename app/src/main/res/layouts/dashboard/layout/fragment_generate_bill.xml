<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceVariant">

    <!-- Custom Top Action Bar / Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="?attr/colorOnSurface"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btnBack"
            android:layout_centerVertical="true"
            android:layout_marginStart="24dp"
            android:textAppearance="@style/TextAppearance.App.LabelTitle"
            android:textSize="18sp"
            tools:text="Generate Bill for Room 101" />
    </RelativeLayout>

    <!-- Main Card Body Container -->
    <com.google.android.material.card.MaterialCardView
        style="?attr/materialCardViewStyle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="16dp">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Tenant Info Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelBody"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:text="Tenant:" />

                <TextView
                    android:id="@+id/tvTenantName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelTitle"
                    android:textSize="24sp"
                    android:layout_marginTop="2dp"
                    tools:text="Alex Johnson" />

                <TextView
                    android:id="@+id/tvRoomNumberLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelBody"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"
                    tools:text="Room 101" />

                <!-- Scan Subtitle Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LabelTitle"
                    android:textSize="14sp"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp"
                    android:text="Pre-filled Readings (detected from scan)" />

                <!-- Initial Reading Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.LabelBody"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="15sp"
                        android:text="Previous Reading :" />
                    <TextView
                        android:id="@+id/tvPreviousReading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:textAppearance="@style/TextAppearance.App.LabelTitle"
                        android:textSize="15sp"
                        tools:text="110.1 kWh" />
                </RelativeLayout>

                <!-- Final Reading Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.LabelBody"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="15sp"
                        android:text="Current Reading :" />
                    <TextView
                        android:id="@+id/tvCurrentReading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:textAppearance="@style/TextAppearance.App.LabelTitle"
                        android:textSize="15sp"
                        tools:text="123.4 kWh" />
                </RelativeLayout>

                <!-- View OCR Link Button -->
                <TextView
                    android:id="@+id/btnViewOcr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:textAppearance="@style/TextAppearance.App.LabelTitle"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="View OCR Image" />

                <!-- Units Consumed Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.LabelBody"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="15sp"
                        android:text="Units Consumed" />
                    <TextView
                        android:id="@+id/tvUnitsConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:textAppearance="@style/TextAppearance.App.LabelTitle"
                        android:textSize="15sp"
                        tools:text="13.3 kWh" />
                </RelativeLayout>

                <!-- Unit Rate Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.LabelBody"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="15sp"
                        android:text="Unit Rate" />
                    <TextView
                        android:id="@+id/tvUnitRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:textAppearance="@style/TextAppearance.App.LabelTitle"
                        android:textSize="15sp"
                        tools:text="₹10/kWh" />
                </RelativeLayout>

                <!-- Calculation Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.LabelBody"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="15sp"
                        android:text="Calculation" />
                    <TextView
                        android:id="@+id/tvCalculation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:textAppearance="@style/TextAppearance.App.LabelTitle"
                        android:textSize="15sp"
                        tools:text="13.3 * 10 = ₹133" />
                </RelativeLayout>

                <!-- Fixed Charges Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.LabelBody"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="15sp"
                        android:text="Plus Fixed Charges" />
                    <TextView
                        android:id="@+id/tvFixedCharges"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:textAppearance="@style/TextAppearance.App.LabelTitle"
                        android:textSize="15sp"
                        tools:text="₹100" />
                </RelativeLayout>

                <!-- Horizontal Separator Line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceVariant"
                    android:layout_marginBottom="16dp" />

                <!-- Total Bill Block -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="40dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.LabelTitle"
                        android:textSize="16sp"
                        android:text="Total Bill Amount" />
                    <TextView
                        android:id="@+id/tvTotalAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:textAppearance="@style/TextAppearance.App.LabelTitle"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="16sp"
                        tools:text="₹233" />
                </RelativeLayout>

                <!-- Bottom Action Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGenerateSendBill"
                    style="?attr/materialButtonStyle"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Generate &amp; Send Bill"
                    android:textAllCaps="false"
                    android:textSize="16sp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>