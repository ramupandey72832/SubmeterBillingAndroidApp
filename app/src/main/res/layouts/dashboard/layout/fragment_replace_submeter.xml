<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurfaceVariant"
    tools:context=".fragments.ReplaceSubmeterFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title Header -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textAppearance="@style/TextAppearance.App.LabelTitle"
            android:textSize="24sp"
            android:text="Replace Submeter" />

        <!-- Subtitle Context description -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"
            android:textAppearance="@style/TextAppearance.App.LabelBody"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:text="Enter the details below to update the submeter serial number." />

        <!-- Identification Field: Room Number -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRoomNumber"
            style="?attr/textInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Room Number"
            app:startIconDrawable="@drawable/ic_menu_home"
            app:startIconTint="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRoomNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Semantic Text Divider Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:background="?attr/colorSurfaceVariant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.App.LabelTitle"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginHorizontal="16dp"
                android:text="OR" />

            <View
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:background="?attr/colorSurfaceVariant" />
        </LinearLayout>

        <!-- Identification Field: Old Meter Number -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilOldMeterNumber"
            style="?attr/textInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Old Meter Number"
            app:startIconDrawable="@android:drawable/ic_menu_compass"
            app:startIconTint="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etOldMeterNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Input Field: New Meter Serial Number -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNewSerialNumber"
            style="?attr/textInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="New Meter Serial Number"
            app:startIconDrawable="@android:drawable/ic_input_add"
            app:startIconTint="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNewSerialNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Core Update Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdate"
            style="?attr/materialButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Update Submeter"
            android:textSize="16sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>